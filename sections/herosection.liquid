                </svg>
              {%- endif -%}
            </span>
          </div>

          {%- if section.settings.trust_subtitle != blank -%}
            <p class="hero__trust-subtitle">{{ section.settings.trust_subtitle }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

<style>
  .hero--{{ section.id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: var(--hero-mobile-bg);
    color: var(--hero-text-color);
  }

  /* ===== Background image (desktop) ===== */
  .hero--{{ section.id }} .hero__bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    z-index: 0;
  }

  /* ===== Image mobile (cachée en desktop) ===== */
  .hero--{{ section.id }} .hero__mobile-media {
    display: none;
  }
  .hero--{{ section.id }} .hero__mobile-media img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  /* ===== Overlay desktop ===== */
  .hero--{{ section.id }} .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, calc(var(--hero-overlay-opacity) * 1.1)) 0%,
      rgba(0, 0, 0, var(--hero-overlay-opacity)) 35%,
      rgba(0, 0, 0, calc(var(--hero-overlay-opacity) * 0.4)) 65%,
      rgba(0, 0, 0, 0) 100%
    );
    z-index: 1;
  }
  /* Si on aligne à droite, on inverse le gradient */
  .hero--{{ section.id }}[style*="--hero-content-align: flex-end"] .hero__overlay {
    background: linear-gradient(
      270deg,
      rgba(0, 0, 0, calc(var(--hero-overlay-opacity) * 1.1)) 0%,
      rgba(0, 0, 0, var(--hero-overlay-opacity)) 35%,
      rgba(0, 0, 0, calc(var(--hero-overlay-opacity) * 0.4)) 65%,
      rgba(0, 0, 0, 0) 100%
    );
  }

  /* ===== Container & contenu ===== */
  .hero--{{ section.id }} .hero__container {
    position: relative;
    z-index: 2;
    max-width: 1400px;
    margin: 0 auto;
    padding: 80px 24px;
    min-height: var(--hero-min-height-desktop);
    display: flex;
    align-items: center;
    justify-content: var(--hero-content-align, flex-start);
  }

  .hero--{{ section.id }} .hero__content {
    max-width: 620px;
    width: 100%;
  }

  /* ===== Titre ===== */
  .hero--{{ section.id }} .hero__title {
    font-size: var(--hero-title-size-desktop);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.01em;
    margin: 0 0 20px 0;
    color: var(--hero-text-color);
    text-transform: uppercase;
  }

  .hero--{{ section.id }} .hero__highlight {
    color: var(--hero-highlight-color);
  }

  /* ===== Description ===== */
  .hero--{{ section.id }} .hero__description {
    font-size: var(--hero-description-size-desktop);
    line-height: 1.55;
    color: var(--hero-description-color);
    margin: 0 0 28px 0;
    max-width: 540px;
  }

  .hero--{{ section.id }} .hero__description p {
    margin: 0 0 8px 0;
  }
  .hero--{{ section.id }} .hero__description strong {
    font-weight: 700;
  }

  /* ===== Bouton ===== */
  .hero--{{ section.id }} .hero__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 16px 32px;
    border-radius: 8px;
    background-color: var(--hero-button-bg);
    color: var(--hero-button-text);
    font-size: var(--hero-button-size);
    font-weight: 600;
    text-decoration: none;
    transition: background-color 0.2s ease, transform 0.2s ease;
    margin-bottom: 24px;
  }
  .hero--{{ section.id }} .hero__button:hover {
    background-color: var(--hero-button-bg-hover);
    transform: translateY(-1px);
  }

  /* ===== Trust badge ===== */
  .hero--{{ section.id }} .hero__trust {
    display: flex;
    flex-direction: column;
    gap: 4px;
    margin-top: 8px;
  }

  .hero--{{ section.id }} .hero__trust-row {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .hero--{{ section.id }} .hero__trust-label {
    color: var(--hero-trust-label-color);
    font-weight: 700;
    font-size: var(--hero-trust-label-size);
  }

  .hero--{{ section.id }} .hero__trust-stars,
  .hero--{{ section.id }} .hero__trust-logo {
    display: inline-flex;
    align-items: center;
    color: var(--hero-trust-label-color);
  }
  .hero--{{ section.id }} .hero__trust-stars img,
  .hero--{{ section.id }} .hero__trust-stars svg {
    height: 20px;
    width: auto;
  }
  .hero--{{ section.id }} .hero__trust-logo img,
  .hero--{{ section.id }} .hero__trust-logo svg {
    height: 22px;
    width: auto;
  }

  .hero--{{ section.id }} .hero__trust-subtitle {
    font-size: var(--hero-trust-subtitle-size);
    color: var(--hero-trust-subtitle-color);
    font-weight: 600;
    margin: 0;
  }

  /* =====================================================
     MOBILE : on switche en mode "image en haut + contenu en bas"
     ===================================================== */
  @media (max-width: 749px) {
    .hero--{{ section.id }} {
      background-color: var(--hero-mobile-bg);
    }

    .hero--{{ section.id }} .hero__bg,
    .hero--{{ section.id }} .hero__overlay {
      display: none;
    }

    .hero--{{ section.id }} .hero__mobile-media {
      display: block;
      width: 100%;
    }

    .hero--{{ section.id }} .hero__container {
      min-height: auto;
      padding: 28px 20px 40px;
      justify-content: flex-start;
    }

    .hero--{{ section.id }} .hero__content {
      max-width: 100%;
    }

    .hero--{{ section.id }} .hero__title {
      font-size: var(--hero-title-size-mobile);
      margin-bottom: 14px;
    }

    .hero--{{ section.id }} .hero__description {
      font-size: var(--hero-description-size-mobile);
      margin-bottom: 20px;
    }

    .hero--{{ section.id }} .hero__button {
      width: 100%;
      padding: 14px 20px;
    }

    .hero--{{ section.id }} .hero__trust-row {
      gap: 8px;
    }
  }
</style>

{% schema %}
{
  "name": "Hero Banner",
  "tag": "section",
  "class": "section-hero-banner",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_desktop",
      "label": "Image desktop (paysage, ≥ 1920px)"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Image mobile (optionnelle)",
      "info": "Si vide, l'image desktop sera utilisée. Format portrait ou paysage selon vos préférences."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Texte alternatif (SEO / accessibilité)"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Hauteur minimum (desktop)",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "default": 600
    },
    {
      "type": "header",
      "content": "Overlay (desktop)"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Couleur de l'overlay",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Opacité de l'overlay (%)",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 50
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Position du contenu (desktop)",
      "options": [
        { "value": "flex-start", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "flex-end", "label": "Droite" }
      ],
      "default": "flex-start"
    },
    {
      "type": "header",
      "content": "Titre"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Titre",
      "info": "Entourez les mots à mettre en couleur avec **double astérisques**. Exemple : VOTRE STUDIO **CLÉS EN MAIN**",
      "default": "VOTRE STUDIO DE JARDIN\n**CLÉS EN MAIN** INSTALLÉ\nEN **5 JOURS** SEULEMENT"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Couleur du titre",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "highlight_color",
      "label": "Couleur des mots mis en avant",
      "default": "#7DD3B7"
    },
    {
      "type": "header",
      "content": "Tailles de texte"
    },
    {
      "type": "range",
      "id": "title_size_desktop",
      "label": "Taille du titre (desktop)",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Taille du titre (mobile)",
      "min": 18,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "description_size_desktop",
      "label": "Taille de la description (desktop)",
      "min": 12,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "description_size_mobile",
      "label": "Taille de la description (mobile)",
      "min": 11,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Taille du texte du bouton",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "trust_label_size",
      "label": "Taille de la mention (Excellent)",
      "min": 11,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "trust_subtitle_size",
      "label": "Taille du texte sous le badge",
      "min": 10,
