{% comment %}
  Section : Hero Banner
  -----------------------------------------------------------
  Comportement :
   - Desktop : image de fond plein largeur + contenu superposé (à gauche, centre ou droite)
   - Mobile  : image en haut + contenu sur fond coloré en dessous
  Personnalisable :
   - Image desktop & mobile (séparées)
   - Titre multi-lignes avec mots mis en avant via **mot**
   - Description, bouton, badge avis (stars + logo)
   - Couleurs (overlay, fond mobile, textes, bouton…)
  Installation :
   1) Online Store > Themes > Edit code
   2) Sections > Add a new section > nommez-la "hero-banner"
   3) Collez ce fichier, puis ajoutez la section depuis l'éditeur de thème.
{% endcomment %}

{% comment %} Préparation du titre : on remplace **mot** par <span class="hl">mot</span> {% endcomment %}
{%- assign raw_title = section.settings.title | newline_to_br -%}
{%- assign title_parts = raw_title | split: '**' -%}

<section
  class="hero hero--{{ section.id }}"
  style="
    --hero-min-height-desktop: {{ section.settings.height_desktop }}px;
    --hero-overlay-color: {{ section.settings.overlay_color }};
    --hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --hero-mobile-bg: {{ section.settings.mobile_bg_color }};
    --hero-text-color: {{ section.settings.text_color }};
    --hero-highlight-color: {{ section.settings.highlight_color }};
    --hero-description-color: {{ section.settings.description_color }};
    --hero-button-bg: {{ section.settings.button_bg }};
    --hero-button-bg-hover: {{ section.settings.button_bg_hover }};
    --hero-button-text: {{ section.settings.button_text_color }};
    --hero-trust-label-color: {{ section.settings.trust_label_color }};
    --hero-trust-subtitle-color: {{ section.settings.trust_subtitle_color }};
    --hero-content-align: {{ section.settings.content_align }};
    --hero-title-size-desktop: {{ section.settings.title_size_desktop }}px;
    --hero-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --hero-description-size-desktop: {{ section.settings.description_size_desktop }}px;
    --hero-description-size-mobile: {{ section.settings.description_size_mobile }}px;
    --hero-button-size: {{ section.settings.button_size }}px;
    --hero-trust-label-size: {{ section.settings.trust_label_size }}px;
    --hero-trust-subtitle-size: {{ section.settings.trust_subtitle_size }}px;
  "
>
  {% comment %} ---- Image desktop (background) ---- {% endcomment %}
  {%- if section.settings.image_desktop != blank -%}
    <div
      class="hero__bg"
      style="background-image: url({{ section.settings.image_desktop | image_url: width: 2400 }});"
      role="img"
      aria-label="{{ section.settings.image_alt | default: section.settings.title | strip_html | escape }}"
    ></div>
  {%- endif -%}

  {% comment %} ---- Image mobile (au-dessus du contenu) ---- {% endcomment %}
  <div class="hero__mobile-media">
    {%- assign mobile_img = section.settings.image_mobile | default: section.settings.image_desktop -%}
    {%- if mobile_img != blank -%}
      <img
        src="{{ mobile_img | image_url: width: 900 }}"
        srcset="{{ mobile_img | image_url: width: 600 }} 600w, {{ mobile_img | image_url: width: 900 }} 900w, {{ mobile_img | image_url: width: 1200 }} 1200w"
        sizes="100vw"
        alt="{{ section.settings.image_alt | default: section.settings.title | strip_html | escape }}"
        loading="eager"
        width="900"
        height="600"
      >
    {%- endif -%}
  </div>

  {% comment %} ---- Overlay (gradient sombre derrière le texte sur desktop) ---- {% endcomment %}
  <div class="hero__overlay"></div>

  {% comment %} ---- Contenu ---- {% endcomment %}
  <div class="hero__container">
    <div class="hero__content">

      {%- if raw_title != blank -%}
        <h1 class="hero__title">
          {%- for part in title_parts -%}
            {%- assign part_mod = forloop.index0 | modulo: 2 -%}
            {%- if part_mod == 0 -%}
              {{ part }}
            {%- else -%}
              <span class="hero__highlight">{{ part }}</span>
            {%- endif -%}
          {%- endfor -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="hero__description">{{ section.settings.description }}</div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="hero__button">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.show_trust -%}
        <div class="hero__trust">
          <div class="hero__trust-row">
            {%- if section.settings.trust_label != blank -%}
              <span class="hero__trust-label">{{ section.settings.trust_label }}</span>
            {%- endif -%}

            <span class="hero__trust-stars">
              {%- if section.settings.rating_image != blank -%}
                <img src="{{ section.settings.rating_image | image_url: width: 264 }}" alt="Note" height="20">
              {%- else -%}
                {% comment %} Étoiles par défaut (4.5/5 — Trustpilot style) {% endcomment %}
                <svg xmlns="http://www.w3.org/2000/svg" width="132" height="25" viewBox="0 0 132 25" fill="none" aria-hidden="true">
                  <path d="M25 0H0V25H25V0Z" fill="#00B67A"/>
