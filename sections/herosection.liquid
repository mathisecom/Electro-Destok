                  <path d="M52 0H27V25H52V0Z" fill="#00B67A"/>
                  <path d="M39.5 16.85L43.3 15.88L44.89 20.78L39.5 16.85ZM48.25 10.52H41.56L39.5 4.22L37.44 10.52H30.75L36.17 14.43L34.11 20.73L39.53 16.82L42.86 14.43L48.25 10.52Z" fill="#fff"/>
                  <path d="M79 0H54V25H79V0Z" fill="#00B67A"/>
                  <path d="M66.5 16.85L70.3 15.88L71.89 20.78L66.5 16.85ZM75.25 10.52H68.56L66.5 4.22L64.44 10.52H57.75L63.17 14.43L61.11 20.73L66.53 16.82L69.86 14.43L75.25 10.52Z" fill="#fff"/>
                  <path d="M106 0H81V25H106V0Z" fill="#00B67A"/>
                  <path d="M93.5 16.85L97.3 15.88L98.89 20.78L93.5 16.85ZM102.25 10.52H95.56L93.5 4.22L91.44 10.52H84.75L90.17 14.43L88.11 20.73L93.53 16.82L96.86 14.43L102.25 10.52Z" fill="#fff"/>
                  <path d="M121 0H108V25H121V0Z" fill="#00B67A"/>
                  <path d="M132 0H121V25H132V0Z" fill="#DDDDDD"/>
                  <path d="M120.5 16.85L124.3 15.88L125.89 20.78L120.5 16.85ZM129.25 10.52H122.56L120.5 4.22L118.44 10.52H111.75L117.17 14.43L115.11 20.73L120.53 16.82L123.86 14.43L129.25 10.52Z" fill="#fff"/>
                </svg>
              {%- endif -%}
            </span>

            <span class="hero__trust-logo">
              {%- if section.settings.logo_image != blank -%}
                <img src="{{ section.settings.logo_image | image_url: width: 322 }}" alt="Logo avis" height="20">
              {%- else -%}
                {% comment %} Logo Trustpilot par défaut (texte + étoile) {% endcomment %}
                <svg xmlns="http://www.w3.org/2000/svg" width="120" height="28" viewBox="0 0 161 37" fill="none" aria-hidden="true">
                  <g>
                    <path d="M36 14.6H22.26L18.01 0.84L13.74 14.6L0 14.59l11.13 8.51L6.87 36.84 18 28.35l11.12 8.49L24.87 23.1 35.99 14.6Z" fill="#00B67A"/>
                    <path d="M25.83 26.21l-0.96-3.11L18 28.35l7.83-2.13Z" fill="#005128"/>
                  </g>
