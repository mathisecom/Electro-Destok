      "label": "Couleur du titre",
      "default": "#8f969d"
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "label": "Espace sous le titre PC",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "mobile_heading_margin_bottom",
      "label": "Espace sous le titre mobile",
      "min": 0,
      "max": 70,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "header",
