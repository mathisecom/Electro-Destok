      "unit": "vw",
      "default": 44
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Largeur carte mobile",
      "min": 65,
      "max": 95,
      "step": 1,
      "unit": "vw",
      "default": 68
    },
    {
      "type": "range",
      "id": "mobile_cards_gap",
      "label": "Espace entre les cartes mobile",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 8
