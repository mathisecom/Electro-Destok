{% comment %}
  Section: Collection Slider Premium
{% endcomment %}

<section class="premium-collection-section section-{{ section.id }}">
  <div class="premium-collection-wrapper">

    {% if section.settings.heading != blank %}
      <h2 class="premium-collection-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% assign selected_collection = section.settings.collection %}

    {% if selected_collection != blank and selected_collection.products_count > 0 %}
      <div class="premium-product-slider">
        {% for product in selected_collection.products limit: section.settings.products_limit %}
          <a href="{{ product.url }}" class="premium-product-card">

            {% if product.featured_image %}
              <div
                class="premium-product-image"
                style="background-image: url('{{ product.featured_image | image_url: width: 900 }}');"
              ></div>
            {% endif %}

            <div class="premium-product-overlay"></div>

            {% if section.settings.show_badges %}
              <div class="premium-product-badge">
                {% if product.tags contains 'bestseller' %}
                  Bestseller
                {% elsif product.tags contains 'populaire' %}
                  Populaire
                {% elsif product.tags contains 'nouveaute' %}
                  Nouveauté
                {% elsif product.tags contains 'eco' %}
                  Economies d’énergie
                {% else %}
                  {{ section.settings.default_badge }}
                {% endif %}
              </div>
            {% endif %}

            <div class="premium-product-content">
              <h3 class="premium-product-title">
                {{ product.title }}
              </h3>

              <p class="premium-product-description">
                {% if product.metafields.custom.short_description != blank %}
                  {{ product.metafields.custom.short_description }}
                {% else %}
                  {{ product.description | strip_html | truncate: 85 }}
                {% endif %}
              </p>

              <div class="premium-product-button">
                {{ section.settings.button_text }}
                <span>→</span>
              </div>
            </div>

          </a>
        {% endfor %}
      </div>
    {% else %}
      <p class="premium-empty-message">
        Sélectionne une collection dans les paramètres de la section.
      </p>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  .section-{{ section.id }} .premium-collection-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-{{ section.id }} .premium-collection-title {
    margin: 0 0 28px;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: 800;
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.04em;
  }

  .section-{{ section.id }} .premium-product-slider {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - 36px) / {{ section.settings.cards_desktop }});
    gap: 12px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 8px;
  }

  .section-{{ section.id }} .premium-product-slider::-webkit-scrollbar {
    display: none;
  }

  .section-{{ section.id }} .premium-product-slider {
    scrollbar-width: none;
  }

  .section-{{ section.id }} .premium-product-card {
    position: relative;
    min-height: {{ section.settings.card_height }}px;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    color: #fff;
    scroll-snap-align: start;
    isolation: isolate;
    background: #1f1a16;
  }

  .section-{{ section.id }} .premium-product-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.45s ease;
    z-index: -3;
  }

  .section-{{ section.id }} .premium-product-card:hover .premium-product-image {
    transform: scale(1.05);
  }

  .section-{{ section.id }} .premium-product-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0.08) 0%,
      rgba(0, 0, 0, 0.18) 42%,
      rgba(0, 0, 0, 0.62) 100%
    );
    z-index: -2;
  }

  .section-{{ section.id }} .premium-product-badge {
    position: absolute;
    top: 22px;
    left: 22px;
    padding: 7px 14px;
    border-radius: 4px;
    background: rgba(255, 255, 255, 0.22);
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: #fff;
    font-size: 11px;
    line-height: 1;
    font-weight: 800;
    backdrop-filter: blur(8px);
    z-index: 3;
  }

  .section-{{ section.id }} .premium-product-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: 24px 20px 18px;
  }

  .section-{{ section.id }} .premium-product-title {
    margin: 0 0 12px;
    font-size: 25px;
    line-height: 1.05;
    font-weight: 900;
    color: #fff;
    letter-spacing: -0.05em;
  }

  .section-{{ section.id }} .premium-product-description {
    margin: 0 0 28px;
    font-size: 13px;
    line-height: 1.45;
    font-weight: 700;
    color: rgba(255, 255, 255, 0.96);
  }

  .section-{{ section.id }} .premium-product-button {
    width: fit-content;
    min-width: 118px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: 12px 20px;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.28);
    border: 1px solid rgba(255, 255, 255, 0.95);
    color: #fff;
    font-size: 13px;
    font-weight: 800;
    line-height: 1;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .premium-product-card:hover .premium-product-button {
    background: rgba(255, 255, 255, 0.38);
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .premium-product-button span {
    font-size: 19px;
    line-height: 1;
  }

  .section-{{ section.id }} .premium-empty-message {
    color: #777;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .premium-product-slider {
      grid-auto-columns: 44vw;
    }

    .section-{{ section.id }} .premium-product-card {
      min-height: {{ section.settings.card_height_tablet }}px;
    }
  }

  @media screen and (max-width: 699px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .premium-collection-wrapper {
      padding: 0 14px;
    }

    .section-{{ section.id }} .premium-collection-title {
      font-size: {{ section.settings.mobile_heading_size }}px;
      margin-bottom: 22px;
    }

    .section-{{ section.id }} .premium-product-slider {
      grid-auto-columns: {{ section.settings.mobile_card_width }}vw;
      gap: 8px;
      padding-right: 14px;
    }

    .section-{{ section.id }} .premium-product-card {
      min-height: {{ section.settings.card_height_mobile }}px;
      border-radius: {{ section.settings.mobile_card_radius }}px;
    }

    .section-{{ section.id }} .premium-product-badge {
      top: 24px;
      left: 25px;
      padding: 7px 14px;
      font-size: 11px;
    }

    .section-{{ section.id }} .premium-product-content {
      padding: 22px 12px 14px;
    }

    .section-{{ section.id }} .premium-product-title {
      font-size: 23px;
      margin-bottom: 12px;
    }

    .section-{{ section.id }} .premium-product-description {
      font-size: 15px;
      line-height: 1.45;
      margin-bottom: 30px;
    }

    .section-{{ section.id }} .premium-product-button {
      width: 100%;
      padding: 16px 20px;
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection slider premium",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos climatiseurs"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection à afficher"
    },
    {
      "type": "range",
      "id": "products_limit",
      "label": "Nombre de produits",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texte du bouton",
      "default": "Je découvre"
    },
    {
      "type": "checkbox",
      "id": "show_badges",
      "label": "Afficher les badges",
      "default": true
    },
    {
      "type": "text",
      "id": "default_badge",
      "label": "Badge par défaut",
      "default": "Bestseller"
    },
    {
      "type": "range",
      "id": "cards_desktop",
      "label": "Nombre de cartes visibles sur PC",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Largeur carte mobile",
      "min": 65,
      "max": 95,
      "step": 1,
      "unit": "vw",
      "default": 68
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Hauteur carte PC",
      "min": 280,
      "max": 620,
      "step": 10,
      "unit": "px",
      "default": 360
    },
    {
      "type": "range",
      "id": "card_height_tablet",
      "label": "Hauteur carte tablette",
      "min": 280,
      "max": 620,
      "step": 10,
      "unit": "px",
      "default": 390
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "label": "Hauteur carte mobile",
      "min": 300,
      "max": 680,
      "step": 10,
      "unit": "px",
      "default": 390
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arrondi carte PC",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "mobile_card_radius",
      "label": "Arrondi carte mobile",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 7
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largeur maximum",
      "min": 900,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1140
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre PC",
      "min": 20,
      "max": 60,
      "step": 1,
      "unit": "px",
      "default": 31
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Taille titre mobile",
      "min": 20,
      "max": 44,
      "step": 1,
      "unit": "px",
      "default": 29
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Couleur du titre",
      "default": "#8f969d"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Couleur de fond",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Marge haute PC",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Marge basse PC",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Marge haute mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Marge basse mobile",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    }
  ],
  "presets": [
    {
      "name": "Collection slider premium"
    }
  ]
}
{% endschema %}