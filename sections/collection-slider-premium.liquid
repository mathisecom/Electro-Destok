{% comment %}
  Section: Collection Cards Slider Premium
{% endcomment %}

<section class="premium-collection-section section-{{ section.id }}">
  <div class="premium-collection-wrapper">

    {% if section.settings.heading != blank %}
      <h2 class="premium-collection-title">
        {{ section.settings.heading }}
      </h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      <div class="premium-product-slider">
        {% for block in section.blocks %}
          {% assign card_collection = block.settings.collection %}
          {% assign card_title = block.settings.title %}
          {% assign card_description = block.settings.description %}
          {% assign card_image = block.settings.image %}

          <a
            href="{% if card_collection != blank %}{{ card_collection.url }}{% else %}#{% endif %}"
            class="premium-product-card"
            {{ block.shopify_attributes }}
          >

            {% if card_image != blank %}
              <div
                class="premium-product-image"
                style="background-image: url('{{ card_image | image_url: width: 1000 }}');"
              ></div>
            {% elsif card_collection != blank and card_collection.featured_image != blank %}
              <div
                class="premium-product-image"
                style="background-image: url('{{ card_collection.featured_image | image_url: width: 1000 }}');"
              ></div>
            {% endif %}

            <div class="premium-product-overlay"></div>

            {% if block.settings.show_badge and block.settings.badge != blank %}
              <div class="premium-product-badge">
                {{ block.settings.badge }}
              </div>
            {% endif %}

            <div class="premium-product-content">
              <h3
                class="premium-product-title"
                style="
                  font-size: {{ block.settings.title_size }}px;
                "
              >
                {% if card_title != blank %}
                  {{ card_title }}
                {% elsif card_collection != blank %}
                  {{ card_collection.title }}
                {% else %}
                  Titre de la collection
                {% endif %}
              </h3>

              {% if block.settings.show_description %}
                <p
                  class="premium-product-description"
                  style="
                    font-size: {{ block.settings.description_size }}px;
                  "
                >
                  {% if card_description != blank %}
                    {{ card_description }}
                  {% elsif card_collection != blank and card_collection.description != blank %}
                    {{ card_collection.description | strip_html | truncate: 90 }}
                  {% else %}
                    Ajoute une description dans les paramètres de cette card.
                  {% endif %}
                </p>
              {% endif %}

              {% if section.settings.show_button %}
                <div class="premium-product-button">
                  {{ section.settings.button_text }}
                  <span>→</span>
                </div>
              {% endif %}
            </div>

          </a>
        {% endfor %}
      </div>
    {% else %}
      <p class="premium-empty-message">
        Ajoute des cards dans les paramètres de la section.
      </p>
    {% endif %}

  </div>
</section>

<style>
  .section-{{ section.id }} {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background: {{ section.settings.background_color }};
  }

  .section-{{ section.id }} .premium-collection-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .section-{{ section.id }} .premium-collection-title {
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.1;
    font-weight: {{ section.settings.heading_weight }};
    color: {{ section.settings.heading_color }};
    letter-spacing: -0.04em;
  }

  .section-{{ section.id }} .premium-product-slider {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - ({{ section.settings.cards_gap }}px * ({{ section.settings.cards_desktop }} - 1))) / {{ section.settings.cards_desktop }});
    gap: {{ section.settings.cards_gap }}px;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-padding-left: 0;
    -webkit-overflow-scrolling: touch;
    padding-bottom: 10px;
  }

  .section-{{ section.id }} .premium-product-slider::-webkit-scrollbar {
    display: none;
  }

  .section-{{ section.id }} .premium-product-slider {
    scrollbar-width: none;
  }

  .section-{{ section.id }} .premium-product-card {
    position: relative;
    min-height: {{ section.settings.card_height }}px;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    text-decoration: none;
    color: #fff;
    scroll-snap-align: start;
    isolation: isolate;
    background: #1f1a16;
    box-shadow: 0 {{ section.settings.shadow_y }}px {{ section.settings.shadow_blur }}px rgba(0, 0, 0, {{ section.settings.shadow_opacity | divided_by: 100.0 }});
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }

  .section-{{ section.id }} .premium-product-card:hover {
    transform: translateY(-{{ section.settings.hover_lift }}px);
    box-shadow: 0 {{ section.settings.shadow_y | plus: 4 }}px {{ section.settings.shadow_blur | plus: 10 }}px rgba(0, 0, 0, {{ section.settings.shadow_opacity | plus: 6 | divided_by: 100.0 }});
  }

  .section-{{ section.id }} .premium-product-image {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transition: transform 0.45s ease;
    z-index: -3;
  }

  .section-{{ section.id }} .premium-product-card:hover .premium-product-image {
    transform: scale({{ section.settings.image_zoom | divided_by: 100.0 }});
  }

  .section-{{ section.id }} .premium-product-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, {{ section.settings.overlay_top | divided_by: 100.0 }}) 0%,
      rgba(0, 0, 0, {{ section.settings.overlay_middle | divided_by: 100.0 }}) 45%,
      rgba(0, 0, 0, {{ section.settings.overlay_bottom | divided_by: 100.0 }}) 100%
    );
    z-index: -2;
  }

  .section-{{ section.id }} .premium-product-badge {
    position: absolute;
    top: {{ section.settings.badge_top }}px;
    left: {{ section.settings.badge_left }}px;
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    border-radius: {{ section.settings.badge_radius }}px;
    background: {{ section.settings.badge_background }};
    border: 1px solid {{ section.settings.badge_border_color }};
    color: {{ section.settings.badge_text_color }};
    font-size: {{ section.settings.badge_size }}px;
    line-height: 1;
    font-weight: 800;
    backdrop-filter: blur(8px);
    z-index: 3;
  }

  .section-{{ section.id }} .premium-product-content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding: {{ section.settings.content_padding_top }}px {{ section.settings.content_padding_x }}px {{ section.settings.content_padding_bottom }}px;
  }

  .section-{{ section.id }} .premium-product-title {
    margin: 0 0 {{ section.settings.title_margin_bottom }}px;
    line-height: 1.05;
    font-weight: {{ section.settings.card_title_weight }};
    color: {{ section.settings.card_title_color }};
    letter-spacing: -0.05em;
  }

  .section-{{ section.id }} .premium-product-description {
    margin: 0 0 {{ section.settings.description_margin_bottom }}px;
    line-height: 1.45;
    font-weight: {{ section.settings.description_weight }};
    color: {{ section.settings.description_color }};
  }

  .section-{{ section.id }} .premium-product-button {
    width: {% if section.settings.button_full_width_desktop %}100%{% else %}fit-content{% endif %};
    min-width: 118px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 9px;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    border-radius: 999px;
    background: {{ section.settings.button_background }};
    border: 1px solid {{ section.settings.button_border_color }};
    color: {{ section.settings.button_text_color }};
    font-size: {{ section.settings.button_size }}px;
    font-weight: 800;
    line-height: 1;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .section-{{ section.id }} .premium-product-card:hover .premium-product-button {
    background: {{ section.settings.button_background_hover }};
    transform: translateY(-2px);
  }

  .section-{{ section.id }} .premium-product-button span {
    font-size: 19px;
    line-height: 1;
  }

  .section-{{ section.id }} .premium-empty-message {
    color: #777;
    font-size: 14px;
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .premium-product-slider {
      grid-auto-columns: {{ section.settings.tablet_card_width }}vw;
    }

    .section-{{ section.id }} .premium-product-card {
      min-height: {{ section.settings.card_height_tablet }}px;
    }
  }

  @media screen and (max-width: 699px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .premium-collection-wrapper {
      padding: 0 {{ section.settings.mobile_side_padding }}px;
    }

    .section-{{ section.id }} .premium-collection-title {
      font-size: {{ section.settings.mobile_heading_size }}px;
      margin-bottom: {{ section.settings.mobile_heading_margin_bottom }}px;
    }

    .section-{{ section.id }} .premium-product-slider {
      grid-auto-columns: {{ section.settings.mobile_card_width }}vw;
      gap: {{ section.settings.mobile_cards_gap }}px;
      padding-right: {{ section.settings.mobile_side_padding }}px;
    }

    .section-{{ section.id }} .premium-product-card {
      min-height: {{ section.settings.card_height_mobile }}px;
      border-radius: {{ section.settings.mobile_card_radius }}px;
    }

    .section-{{ section.id }} .premium-product-badge {
      top: {{ section.settings.mobile_badge_top }}px;
      left: {{ section.settings.mobile_badge_left }}px;
      font-size: {{ section.settings.mobile_badge_size }}px;
    }

    .section-{{ section.id }} .premium-product-content {
      padding: {{ section.settings.mobile_content_padding_top }}px {{ section.settings.mobile_content_padding_x }}px {{ section.settings.mobile_content_padding_bottom }}px;
    }

    .section-{{ section.id }} .premium-product-title {
      line-height: 1.05;
    }

    .section-{{ section.id }} .premium-product-description {
      line-height: 1.45;
    }

    .section-{{ section.id }} .premium-product-button {
      width: {% if section.settings.button_full_width_mobile %}100%{% else %}fit-content{% endif %};
      padding: {{ section.settings.mobile_button_padding_y }}px {{ section.settings.mobile_button_padding_x }}px;
      font-size: {{ section.settings.mobile_button_size }}px;
    }
  }
</style>

{% schema %}
{
  "name": "Collection cards slider",
  "settings": [
    {
      "type": "header",
      "content": "Titre de la section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Nos climatiseurs"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille titre PC",
      "min": 20,
      "max": 70,
      "step": 1,
      "unit": "px",
      "default": 31
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Taille titre mobile",
      "min": 18,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 29
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse du titre",
      "default": "800",
      "options": [
        {
          "value": "500",
          "label": "Moyen"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        },
        {
          "value": "800",
          "label": "Extra-bold"
        },
        {
          "value": "900",
          "label": "Black"
        }
      ]
    },
    {
      "type": "color",
