{% comment %}
  Section: Facade Comparison Premium
{% endcomment %}

<section class="facade-comparison section-{{ section.id }}">
  <div class="facade-comparison__decor"></div>

  <div class="facade-comparison__container">
    <div class="facade-comparison__content">

      {% if section.settings.badge_text != blank %}
        <div class="facade-comparison__badge">
          <span class="facade-comparison__badge-icon">
            {{ section.settings.badge_icon }}
          </span>
          <span>{{ section.settings.badge_text }}</span>
        </div>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="facade-comparison__heading">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="facade-comparison__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      {% if section.blocks.size > 0 %}
        <div class="facade-comparison__features">
          {% for block in section.blocks %}
            <div class="facade-comparison__feature" {{ block.shopify_attributes }}>
              {% if block.settings.icon != blank %}
                <div class="facade-comparison__feature-icon">
                  {{ block.settings.icon }}
                </div>
              {% endif %}

              {% if block.settings.text != blank %}
                <div class="facade-comparison__feature-text">
                  {{ block.settings.text }}
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      {% endif %}

    </div>

    <div class="facade-comparison__visual">
      <div class="facade-comparison__slider" data-comparison-slider>
        {% if section.settings.before_image != blank %}
          <img
            class="facade-comparison__image facade-comparison__image--before"
            src="{{ section.settings.before_image | image_url: width: 1200 }}"
            alt="{{ section.settings.before_image.alt | escape }}"
            loading="lazy"
          >
        {% else %}
          <div class="facade-comparison__placeholder">
            Image avant
          </div>
        {% endif %}

        <div class="facade-comparison__after-wrap" data-after-wrap>
          {% if section.settings.after_image != blank %}
            <img
              class="facade-comparison__image facade-comparison__image--after"
              src="{{ section.settings.after_image | image_url: width: 1200 }}"
              alt="{{ section.settings.after_image.alt | escape }}"
              loading="lazy"
            >
          {% elsif section.settings.before_image != blank %}
            <img
              class="facade-comparison__image facade-comparison__image--after"
              src="{{ section.settings.before_image | image_url: width: 1200 }}"
              alt="{{ section.settings.before_image.alt | escape }}"
              loading="lazy"
            >
          {% else %}
            <div class="facade-comparison__placeholder">
              Image après
            </div>
          {% endif %}
        </div>

        <div class="facade-comparison__divider" data-divider>
          <button class="facade-comparison__handle" type="button" aria-label="Déplacer le comparateur">
            {{ section.settings.slider_icon }}
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: {{ section.settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .section-{{ section.id }} .facade-comparison__decor {
    {% if section.settings.show_decor %}
      display: block;
    {% else %}
      display: none;
    {% endif %}
    position: absolute;
    left: -80px;
    bottom: -130px;
    width: {{ section.settings.decor_size }}px;
    height: {{ section.settings.decor_size }}px;
    opacity: {{ section.settings.decor_opacity | divided_by: 100.0 }};
    pointer-events: none;
    z-index: 0;
  }

  .section-{{ section.id }} .facade-comparison__decor::before,
  .section-{{ section.id }} .facade-comparison__decor::after {
    content: "";
    position: absolute;
    inset: 0;
    background: {{ section.settings.decor_color }};
    border-radius: 60% 40% 60% 40%;
    transform: rotate(35deg);
  }

  .section-{{ section.id }} .facade-comparison__decor::after {
    transform: rotate(125deg);
  }

  .section-{{ section.id }} .facade-comparison__container {
    position: relative;
    z-index: 1;
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding-left: {{ section.settings.side_padding }}px;
    padding-right: {{ section.settings.side_padding }}px;
    display: grid;
    grid-template-columns: {{ section.settings.text_width }}fr {{ section.settings.image_width }}fr;
    align-items: center;
    gap: {{ section.settings.column_gap }}px;
  }

  .section-{{ section.id }} .facade-comparison__content {
    max-width: {{ section.settings.content_max_width }}px;
  }

  .section-{{ section.id }} .facade-comparison__badge {
    width: fit-content;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: {{ section.settings.badge_padding_y }}px {{ section.settings.badge_padding_x }}px;
    margin-bottom: {{ section.settings.badge_margin_bottom }}px;
    border-radius: {{ section.settings.badge_radius }}px;
    background: {{ section.settings.badge_background }};
    color: {{ section.settings.badge_color }};
    font-size: {{ section.settings.badge_size }}px;
    font-weight: {{ section.settings.badge_weight }};
    line-height: 1;
  }

  .section-{{ section.id }} .facade-comparison__badge-icon {
    font-size: {{ section.settings.badge_icon_size }}px;
    line-height: 1;
  }

  .section-{{ section.id }} .facade-comparison__heading {
    margin: 0 0 {{ section.settings.heading_margin_bottom }}px;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    line-height: {{ section.settings.heading_line_height | divided_by: 100.0 }};
    letter-spacing: {{ section.settings.heading_letter_spacing }}px;
  }

  .section-{{ section.id }} .facade-comparison__text {
    margin: 0 0 {{ section.settings.text_margin_bottom }}px;
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size }}px;
    font-weight: {{ section.settings.text_weight }};
    line-height: {{ section.settings.text_line_height | divided_by: 100.0 }};
  }

  .section-{{ section.id }} .facade-comparison__features {
    display: flex;
    flex-direction: column;
    gap: {{ section.settings.features_gap }}px;
  }

  .section-{{ section.id }} .facade-comparison__feature {
    display: flex;
    align-items: center;
    gap: {{ section.settings.feature_icon_gap }}px;
    min-height: {{ section.settings.feature_height }}px;
    padding: {{ section.settings.feature_padding_y }}px {{ section.settings.feature_padding_x }}px;
    border-radius: {{ section.settings.feature_radius }}px;
    background: {{ section.settings.feature_background }};
    box-shadow: 0 {{ section.settings.feature_shadow_y }}px {{ section.settings.feature_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.feature_shadow_opacity | divided_by: 100.0 }});
  }

  .section-{{ section.id }} .facade-comparison__feature-icon {
    flex: 0 0 {{ section.settings.feature_icon_box }}px;
    width: {{ section.settings.feature_icon_box }}px;
    height: {{ section.settings.feature_icon_box }}px;
    border-radius: {{ section.settings.feature_icon_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: {{ section.settings.feature_icon_background }};
    color: {{ section.settings.feature_icon_color }};
    font-size: {{ section.settings.feature_icon_size }}px;
    line-height: 1;
  }

  .section-{{ section.id }} .facade-comparison__feature-text {
    color: {{ section.settings.feature_text_color }};
    font-size: {{ section.settings.feature_text_size }}px;
    font-weight: {{ section.settings.feature_text_weight }};
    line-height: 1.25;
  }

  .section-{{ section.id }} .facade-comparison__visual {
    display: flex;
    justify-content: center;
  }

  .section-{{ section.id }} .facade-comparison__slider {
    --position: {{ section.settings.slider_start }}%;
    position: relative;
    width: 100%;
    max-width: {{ section.settings.image_max_width }}px;
    height: {{ section.settings.image_height }}px;
    border-radius: {{ section.settings.image_radius }}px;
    overflow: hidden;
    user-select: none;
    touch-action: none;
    background: #ddd;
    box-shadow: 0 {{ section.settings.image_shadow_y }}px {{ section.settings.image_shadow_blur }}px rgba(0, 0, 0, {{ section.settings.image_shadow_opacity | divided_by: 100.0 }});
  }

  .section-{{ section.id }} .facade-comparison__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    object-position: {{ section.settings.image_position }};
    pointer-events: none;
  }

  .section-{{ section.id }} .facade-comparison__after-wrap {
    position: absolute;
    inset: 0;
    width: var(--position);
    overflow: hidden;
  }

  .section-{{ section.id }} .facade-comparison__image--after {
    width: {{ section.settings.image_max_width }}px;
    max-width: none;
  }

  .section-{{ section.id }} .facade-comparison__divider {
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--position);
    width: {{ section.settings.divider_width }}px;
    background: {{ section.settings.divider_color }};
    transform: translateX(-50%);
    z-index: 5;
    cursor: ew-resize;
  }

  .section-{{ section.id }} .facade-comparison__handle {
    position: absolute;
    top: {{ section.settings.handle_vertical_position }}%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: {{ section.settings.handle_size }}px;
    height: {{ section.settings.handle_size }}px;
    border-radius: 999px;
    border: none;
    background: {{ section.settings.handle_background }};
    color: {{ section.settings.handle_color }};
    font-size: {{ section.settings.handle_icon_size }}px;
    font-weight: 800;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: ew-resize;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .section-{{ section.id }} .facade-comparison__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #d9d9d9;
    color: #777;
    font-size: 15px;
    font-weight: 700;
  }

  @media screen and (max-width: 989px) {
    .section-{{ section.id }} .facade-comparison__container {
      grid-template-columns: 1fr;
      gap: {{ section.settings.tablet_gap }}px;
    }

    .section-{{ section.id }} .facade-comparison__content {
      max-width: 100%;
    }

    .section-{{ section.id }} .facade-comparison__slider {
      height: {{ section.settings.tablet_image_height }}px;
    }

    .section-{{ section.id }} .facade-comparison__image--after {
      width: 100%;
    }
  }

  @media screen and (max-width: 699px) {
    .section-{{ section.id }} {
      padding-top: {{ section.settings.mobile_padding_top }}px;
      padding-bottom: {{ section.settings.mobile_padding_bottom }}px;
    }

    .section-{{ section.id }} .facade-comparison__container {
      padding-left: {{ section.settings.mobile_side_padding }}px;
      padding-right: {{ section.settings.mobile_side_padding }}px;
      gap: {{ section.settings.mobile_gap }}px;
    }

    .section-{{ section.id }} .facade-comparison__badge {
      font-size: {{ section.settings.mobile_badge_size }}px;
      margin-bottom: {{ section.settings.mobile_badge_margin_bottom }}px;
    }

    .section-{{ section.id }} .facade-comparison__heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      margin-bottom: {{ section.settings.mobile_heading_margin_bottom }}px;
    }

    .section-{{ section.id }} .facade-comparison__text {
      font-size: {{ section.settings.mobile_text_size }}px;
      margin-bottom: {{ section.settings.mobile_text_margin_bottom }}px;
    }

    .section-{{ section.id }} .facade-comparison__features {
      gap: {{ section.settings.mobile_features_gap }}px;
    }

    .section-{{ section.id }} .facade-comparison__feature {
      min-height: {{ section.settings.mobile_feature_height }}px;
      padding: {{ section.settings.mobile_feature_padding_y }}px {{ section.settings.mobile_feature_padding_x }}px;
      border-radius: {{ section.settings.mobile_feature_radius }}px;
    }

    .section-{{ section.id }} .facade-comparison__feature-text {
      font-size: {{ section.settings.mobile_feature_text_size }}px;
    }

    .section-{{ section.id }} .facade-comparison__slider {
      height: {{ section.settings.mobile_image_height }}px;
      border-radius: {{ section.settings.mobile_image_radius }}px;
    }

    .section-{{ section.id }} .facade-comparison__handle {
      width: {{ section.settings.mobile_handle_size }}px;
      height: {{ section.settings.mobile_handle_size }}px;
      font-size: {{ section.settings.mobile_handle_icon_size }}px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const sliders = document.querySelectorAll('.section-{{ section.id }} [data-comparison-slider]');

    sliders.forEach(function (slider) {
      const setPosition = function (clientX) {
        const rect = slider.getBoundingClientRect();
        let position = ((clientX - rect.left) / rect.width) * 100;
        position = Math.max(0, Math.min(100, position));
        slider.style.setProperty('--position', position + '%');
      };

      let isDragging = false;

      slider.addEventListener('mousedown', function (event) {
        isDragging = true;
        setPosition(event.clientX);
      });

      window.addEventListener('mousemove', function (event) {
        if (!isDragging) return;
        setPosition(event.clientX);
      });

      window.addEventListener('mouseup', function () {
        isDragging = false;
      });

      slider.addEventListener('touchstart', function (event) {
        isDragging = true;
        setPosition(event.touches[0].clientX);
      }, { passive: true });

      slider.addEventListener('touchmove', function (event) {
        if (!isDragging) return;
        setPosition(event.touches[0].clientX);
      }, { passive: true });

      slider.addEventListener('touchend', function () {
        isDragging = false;
      });
    });
  });
</script>

{% schema %}
{
  "name": "Image comparaison premium",
  "settings": [
    {
      "type": "header",
      "content": "Contenu"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Texte du badge",
      "default": "Innovation esthétique"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Icône du badge",
      "default": "✧"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titre",
      "default": "Préserver la beauté de votre façade"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Texte",
      "default": "Préservez l'esthétique de votre façade tout en bénéficiant d'un confort optimal"
    },
    {
      "type": "header",
      "content": "Images avant / après"
    },
    {
      "type": "image_picker",
      "id": "before_image",
      "label": "Image avant"
