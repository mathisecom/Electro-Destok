    {
      "type": "image_picker",
      "id": "after_image",
      "label": "Image après"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Ajustement image",
      "default": "cover",
      "options": [
        {
          "value": "cover",
          "label": "Remplir"
        },
        {
          "value": "contain",
          "label": "Contenir"
        }
      ]
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Position image",
      "default": "center center",
      "options": [
        {
          "value": "center center",
          "label": "Centre"
        },
        {
          "value": "top center",
          "label": "Haut"
        },
        {
          "value": "bottom center",
          "label": "Bas"
        },
        {
          "value": "left center",
