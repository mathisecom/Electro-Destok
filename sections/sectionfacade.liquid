      "id": "mobile_heading_size",
      "label": "Taille titre mobile",
      "min": 22,
      "max": 50,
      "step": 1,
      "unit": "px",
      "default": 27
    },
    {
      "type": "select",
      "id": "heading_weight",
      "label": "Graisse titre",
      "default": "400",
      "options": [
        {
          "value": "300",
          "label": "Light"
        },
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Moyen"
        },
        {
          "value": "600",
          "label": "Semi-bold"
