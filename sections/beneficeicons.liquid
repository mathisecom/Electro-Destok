{% comment %}
  ============================================
  Section : Features avec icônes
  ============================================
  - Grille sur Desktop (2 à 6 colonnes au choix)
  - Slider swipeable sur Mobile (avec dots optionnels et autoplay)
  - Icônes, titres, descriptions, couleurs entièrement personnalisables
{% endcomment %}

<style>
  #shopify-section-{{ section.id }} {
    --feat-bg: {{ section.settings.bg_color }};
    --feat-heading-color: {{ section.settings.heading_color }};
    --feat-subheading-color: {{ section.settings.subheading_color }};
    --feat-title-color: {{ section.settings.title_color }};
    --feat-desc-color: {{ section.settings.description_color }};
    --feat-dot: {{ section.settings.dot_color }};
    --feat-dot-active: {{ section.settings.dot_active_color }};
    --feat-cols: {{ section.settings.columns_desktop }};
    --feat-gap: {{ section.settings.gap_size }}px;
    --feat-pt: {{ section.settings.padding_top }}px;
    --feat-pb: {{ section.settings.padding_bottom }}px;
    --feat-pt-mobile: {{ section.settings.padding_top_mobile }}px;
    --feat-pb-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --feat-heading-size: {{ section.settings.heading_size }}px;
    --feat-heading-size-mobile: {{ section.settings.heading_size_mobile }}px;
    --feat-icon-size: {{ section.settings.icon_size }}px;
    --feat-icon-size-mobile: {{ section.settings.icon_size_mobile }}px;
    --feat-title-size: {{ section.settings.title_size }}px;
    --feat-title-size-mobile: {{ section.settings.title_size_mobile }}px;
    --feat-desc-size: {{ section.settings.description_size }}px;
    --feat-card-align: {{ section.settings.card_alignment }};
  }
</style>

<section class="features-section" data-section-id="{{ section.id }}" data-mobile-mode="{{ section.settings.mobile_layout }}" data-show-peek="{{ section.settings.show_peek }}">
  <div class="features-container">

    {%- if section.settings.show_heading and section.settings.heading != blank -%}
      <div class="features-header" style="text-align: {{ section.settings.heading_alignment }};">
        <h2 class="features-heading">{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <div class="features-subheading">{{ section.settings.subheading }}</div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="features-track-wrapper">
      <div class="features-grid" id="features-grid-{{ section.id }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <article class="feature-card" {{ block.shopify_attributes }}>
              {%- if block.settings.icon != blank -%}
                <div class="feature-icon">
                  {{ block.settings.icon | image_url: width: 240 | image_tag:
                    loading: 'lazy',
                    widths: '120, 200, 240',
                    sizes: 'auto',
                    alt: block.settings.title | default: 'icon',
                    class: 'feature-icon-img'
                  }}
                </div>
              {%- endif -%}

              {%- if block.settings.title != blank -%}
                <h3 class="feature-title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.description != blank -%}
                <p class="feature-description">{{ block.settings.description | newline_to_br }}</p>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.mobile_layout == 'slider' and section.settings.show_dots and section.blocks.size > 1 -%}
        <div class="features-dots" role="tablist" aria-label="Navigation features">
          {%- for block in section.blocks -%}
            <button type="button"
                    class="features-dot{% if forloop.first %} is-active{% endif %}"
                    data-slide="{{ forloop.index0 }}"
                    aria-label="Aller à la diapositive {{ forloop.index }}"></button>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

  </div>
</section>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var section = document.querySelector('[data-section-id="' + sectionId + '"]');
    if (!section) return;

    var slider = section.querySelector('.features-grid');
    var dots = section.querySelectorAll('.features-dot');
    var blocksCount = {{ section.blocks.size }};
    var mobileMode = section.dataset.mobileMode;
    var autoplay = {{ section.settings.autoplay | json }};
    var autoplaySpeed = {{ section.settings.autoplay_speed | times: 1000 }};

    if (mobileMode !== 'slider' || blocksCount <= 1) return;

    function isMobile() { return window.innerWidth < 750; }

    function getCardOffset(index) {
      var card = slider.children[index];
      if (!card) return 0;
      return card.offsetLeft - slider.offsetLeft;
    }

    function updateActiveDot() {
      if (!dots.length) return;
      var scrollLeft = slider.scrollLeft;
      var bestIdx = 0;
      var bestDist = Infinity;
      for (var i = 0; i < blocksCount; i++) {
        var dist = Math.abs(scrollLeft - getCardOffset(i));
        if (dist < bestDist) { bestDist = dist; bestIdx = i; }
      }
      for (var j = 0; j < dots.length; j++) {
        dots[j].classList.toggle('is-active', j === bestIdx);
      }
    }

    var scrollTimeout;
    slider.addEventListener('scroll', function() {
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(updateActiveDot, 50);
    }, { passive: true });

    for (var k = 0; k < dots.length; k++) {
      (function(idx) {
        dots[idx].addEventListener('click', function() {
          slider.scrollTo({ left: getCardOffset(idx), behavior: 'smooth' });
        });
      })(k);
    }

    if (autoplay) {
      var current = 0;
      var interval = null;
      var paused = false;

      function tick() {
        if (paused || !isMobile()) return;
        current = (current + 1) % blocksCount;
        slider.scrollTo({ left: getCardOffset(current), behavior: 'smooth' });
      }

      function startAutoplay() {
        stopAutoplay();
        if (isMobile()) interval = setInterval(tick, autoplaySpeed);
      }

      function stopAutoplay() {
        if (interval) { clearInterval(interval); interval = null; }
      }

      startAutoplay();

      window.addEventListener('resize', function() {
        paused = false;
        startAutoplay();
      });

      slider.addEventListener('touchstart', function() { paused = true; }, { passive: true });
      slider.addEventListener('touchend', function() {
        setTimeout(function() { paused = false; }, 2500);
      }, { passive: true });
      slider.addEventListener('mouseenter', function() { paused = true; });
      slider.addEventListener('mouseleave', function() { paused = false; });
    }
  })();
</script>

{% stylesheet %}
  .features-section {
    background-color: var(--feat-bg, #ffffff);
    padding: var(--feat-pt, 80px) 20px var(--feat-pb, 80px);
    width: 100%;
    box-sizing: border-box;
  }

  .features-container {
    max-width: 1280px;
    margin: 0 auto;
  }

  /* ============ HEADER ============ */
  .features-header {
    margin-bottom: 48px;
  }

  .features-heading {
    font-size: var(--feat-heading-size, 36px);
    line-height: 1.2;
    font-weight: 700;
    color: var(--feat-heading-color, #18181b);
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }

  .features-subheading {
    font-size: 16px;
    line-height: 1.5;
    color: var(--feat-subheading-color, #71717a);
    max-width: 640px;
    margin: 0 auto;
  }

  .features-subheading p { margin: 0; }

  /* ============ GRID (DESKTOP) ============ */
  .features-track-wrapper {
    position: relative;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(var(--feat-cols, 4), 1fr);
    gap: var(--feat-gap, 32px);
  }

  /* ============ CARD ============ */
  .feature-card {
    display: flex;
    flex-direction: column;
    align-items: var(--feat-card-align, center);
    text-align: var(--feat-card-align, center);
    padding: 16px 8px;
    box-sizing: border-box;
  }

  .feature-card[data-card-align="flex-start"],
  .features-section[data-card-align="left"] .feature-card {
    align-items: flex-start;
    text-align: left;
  }

  .feature-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    height: var(--feat-icon-size, 80px);
    margin-bottom: 24px;
    width: 100%;
  }

  .feature-icon-img {
    max-height: 100%;
    max-width: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }

  .feature-title {
    font-size: var(--feat-title-size, 18px);
    line-height: 1.3;
    font-weight: 700;
    color: var(--feat-title-color, #18181b);
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }

  .feature-description {
    font-size: var(--feat-desc-size, 15px);
    line-height: 1.5;
    color: var(--feat-desc-color, #71717a);
    margin: 0;
    max-width: 280px;
  }

  /* ============ DOTS ============ */
  .features-dots {
    display: none;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .features-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    border: none;
    background-color: var(--feat-dot, #d4d4d8);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s ease, transform 0.2s ease, width 0.2s ease;
  }

  .features-dot.is-active {
    background-color: var(--feat-dot-active, #18181b);
    width: 24px;
    border-radius: 4px;
  }

  /* ============ RESPONSIVE ============ */
  @media (max-width: 749px) {
    .features-section {
      padding: var(--feat-pt-mobile, 50px) 0 var(--feat-pb-mobile, 50px);
    }

    .features-container {
      padding: 0 16px;
    }

    .features-heading {
      font-size: var(--feat-heading-size-mobile, 26px);
    }

    .features-header {
      margin-bottom: 32px;
    }

    /* Slider mode on mobile */
    .features-section[data-mobile-mode="slider"] .features-container {
      padding: 0;
    }

    .features-section[data-mobile-mode="slider"] .features-header {
      padding: 0 16px;
    }

    .features-section[data-mobile-mode="slider"] .features-grid {
      display: flex;
      grid-template-columns: none;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      scroll-behavior: smooth;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      gap: 0;
      padding: 0 16px;
    }

    .features-section[data-mobile-mode="slider"] .features-grid::-webkit-scrollbar {
      display: none;
    }

    .features-section[data-mobile-mode="slider"] .feature-card {
      flex: 0 0 100%;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }

    /* Peek mode: show edge of next card */
    .features-section[data-mobile-mode="slider"][data-show-peek="true"] .features-grid {
      padding: 0 32px 0 16px;
    }

    .features-section[data-mobile-mode="slider"][data-show-peek="true"] .feature-card {
      flex: 0 0 88%;
      margin-right: 12px;
    }

    .features-section[data-mobile-mode="slider"][data-show-peek="true"] .feature-card:last-child {
      margin-right: 0;
    }

    /* Stack mode on mobile */
    .features-section[data-mobile-mode="grid"] .features-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .features-section[data-mobile-mode="slider"] .features-dots {
      display: flex;
    }

    .feature-icon {
      height: var(--feat-icon-size-mobile, 70px);
      margin-bottom: 18px;
    }

    .feature-title {
      font-size: var(--feat-title-size-mobile, 17px);
      margin-bottom: 10px;
    }
  }

  /* Tablet: reduce columns if too many on desktop */
  @media (min-width: 750px) and (max-width: 989px) {
    .features-grid {
      grid-template-columns: repeat(min(var(--feat-cols, 4), 3), 1fr);
    }
  }

  @media (min-width: 750px) and (max-width: 749px) {
    /* placeholder */
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Features Icônes",
  "tag": "section",
  "class": "section-features-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Titre de section (optionnel)"
    },
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Afficher un titre de section",
      "default": false
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Titre",
      "default": "Pourquoi nous choisir"
    },
    {
      "type": "richtext",
      "id": "subheading",
      "label": "Sous-titre",
      "default": "<p>Découvrez nos engagements et notre savoir-faire.</p>"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignement du titre",
      "options": [
        { "value": "left", "label": "Gauche" },
        { "value": "center", "label": "Centre" },
        { "value": "right", "label": "Droite" }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Mise en page Desktop"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Nombre de colonnes",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "Alignement du contenu des cartes",
      "options": [
        { "value": "center", "label": "Centré" },
        { "value": "flex-start", "label": "Aligné à gauche" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap_size",
      "label": "Espacement entre cartes",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Mode Mobile"
    },
    {
      "type": "select",
      "id": "mobile_layout",
      "label": "Affichage mobile",
      "options": [
        { "value": "slider", "label": "Slider (swipe)" },
        { "value": "grid", "label": "Empilé" }
      ],
      "default": "slider"
    },
    {
      "type": "checkbox",
      "id": "show_peek",
      "label": "Aperçu de la carte suivante",
      "info": "Montre un bord de la carte suivante pour indiquer qu'il y en a plus",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Afficher les puces de navigation",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Défilement automatique sur mobile",
      "default": false
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "label": "Vitesse du défilement auto",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 4
    },
    {
      "type": "header",
      "content": "Tailles"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Taille des icônes (Desktop)",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "icon_size_mobile",
      "label": "Taille des icônes (Mobile)",
      "min": 30,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 70
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Taille du titre de section (Desktop)",
      "min": 20,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Taille du titre de section (Mobile)",
      "min": 16,
      "max": 48,
      "step": 1,
      "unit": "px",
      "default": 26
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Taille du titre des cartes (Desktop)",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "title_size_mobile",
      "label": "Taille du titre des cartes (Mobile)",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "description_size",
      "label": "Taille de la description",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "header",
      "content": "Couleurs"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fond de la section",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Titre de section",
      "default": "#18181b"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Sous-titre de section",
      "default": "#71717a"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Titre des cartes",
      "default": "#18181b"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description",
      "default": "#71717a"
    },
    {
      "type": "color",
      "id": "dot_color",
      "label": "Puce de navigation",
      "default": "#d4d4d8"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Puce active",
      "default": "#18181b"
    },
    {
      "type": "header",
      "content": "Espacements"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding haut (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bas (Desktop)",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "label": "Padding haut (Mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bas (Mobile)",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 50
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "limit": 12,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icône (SVG ou PNG transparent)",
          "info": "Idéalement un SVG ou PNG avec fond transparent"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titre",
          "default": "Titre de la feature"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "info": "Les retours à la ligne sont préservés",
          "default": "Description courte\nsur deux lignes"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Features Icônes",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": "12 ans d'expérience",
            "description": "Fabrication française,\nExpertise éprouvée"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "100% clés en main",
            "description": "De l'étude à la pose,\non s'occupe de tout"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Installation en 5 jours",
            "description": "Sans chantier lourd,\nSans perte de temps"
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "+4000 clients installés",
            "description": "Des clients satisfaits\npartout en France"
          }
        }
      ]
    }
  ]
}
{% endschema %}
